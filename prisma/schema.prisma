// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TipoCliente {
  DIRECTO
  FORWARDER
}

enum TipoProveedor {
  LOGISTICA
  ADUANAL
  GENERALES
}

enum FuenteAltaProveedor {
  MANUAL
  CONSTANCIA
}

enum TipoUsuario {
  ADMIN
  EDITOR
  VIEWER
}

enum EstadoUsuario {
  ACTIVO
  INACTIVO
}

model Cliente {
  id          Int         @id @default(autoincrement())
  folio       String      @unique
  razonSocial String
  rfc         String      @unique
  domicilio   String      @default("No especificado")
  tipo        TipoCliente
  fechaAlta   DateTime    @default(now())
}

model Proveedores {
  id            Int           @id @default(autoincrement())
  tipoProveedor TipoProveedor
  razonSocial   String
  rfc           String        @unique
  correo        String        @unique
  telefono      String
  direccion     String
  fuenteAlta    FuenteAltaProveedor @default(MANUAL)
  fechaAlta     DateTime      @default(now())
}

model Usuario {
  id           Int           @id @default(autoincrement())
  nombre       String
  correo       String        @unique
  tipoUsuario   TipoUsuario   @default(VIEWER)
  estado       EstadoUsuario  @default(ACTIVO)
  passwordHash String
  fechaRegistro DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}